#!/bin/sh
set -e
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

CHANGED=$(git diff --cached --name-only | grep '^acecamp-raw/source/.*\.md$' || true)
if [ -z "$CHANGED" ]; then
  echo "PRE-COMMIT: no staged acecamp source changes, skip"
  exit 0
fi

python3 skills/acecamp-minutes-ingest/scripts/validate_staged_sources.py
